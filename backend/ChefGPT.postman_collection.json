            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/mealplan/generate",
            "body": { "mode": "raw", "raw": "{\n  \"goal\": \"eat_clean\",\n  \"days\": 7,\n  \"calories_target\": 1800,\n  \"dietary_preferences\": [],\n  \"allergies\": []\n}" }
          }
        },
        {
          "name": "Generate Meal Plan — Weight Loss",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/mealplan/generate",
