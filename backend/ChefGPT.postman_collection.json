{
  "info": {
    "name": "ChefGPT API — Full Collection",
    "description": "Complete API test collection for ChefGPT MVP.\n\n**Quick Start:**\n1. Start backend: `cd backend && uvicorn app.main:app --reload`\n2. Run **🔐 Auth / Login** → token tự động lưu vào `{{token}}`\n3. Tất cả request còn lại dùng `{{token}}` qua Bearer Auth của collection\n\n**Sections:**\n  🔐 Auth — Signup, Login, Refresh, Logout\n  💬 Chat — Query, Shopping Intent, Confirm Purchase, History\n  🍳 Recipes — Suggest (AI), List, Save, Delete\n  📸 Vision — Nhận diện nguyên liệu từ ảnh\n  📅 Meal Plan — Generate (AI), List\n  🧠 Memory — Get, Add, Delete\n  🤖 Persona — List, Get, Set, Create, Update, Delete\n  💳 AP2 Payments — Mandate, Place Order, List, Cancel\n  🌐 Community Recipes — Browse, Search (RAG), Stats\n  👥 Social — Mock Feed, CRUD Posts, Like, Comment\n  🛒 Grocery — Mock Shopping List\n  🏥 Health — Root, Docs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",   "value": "http://localhost:8000", "type": "string" },
    { "key": "token",      "value": "",                      "type": "string" },
    { "key": "order_id",   "value": "1",                     "type": "string" },
    { "key": "memory_id",  "value": "1",                     "type": "string" },
    { "key": "persona_id", "value": "asian_chef",            "type": "string" },
    { "key": "recipe_id",  "value": "1",                     "type": "string" },
    { "key": "post_id",    "value": "1",                     "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Signup",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const r = pm.response.json();",
            "if (r.access_token) pm.collectionVariables.set('token', r.access_token);"
          ], "type": "text/javascript" }}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/signup",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"demo@chefgpt.com\",\n  \"password\": \"demo1234\",\n  \"name\": \"Demo User\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.test('Has access_token', () => pm.expect(r.access_token).to.be.a('string'));",
            "pm.collectionVariables.set('token', r.access_token);",
            "console.log('✅ Token saved. Ready to test other endpoints.');"
          ], "type": "text/javascript" }}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"demo@chefgpt.com\",\n  \"password\": \"demo1234\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "if (r.access_token) pm.collectionVariables.set('token', r.access_token);"
          ], "type": "text/javascript" }}],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"PASTE_REFRESH_TOKEN_HERE\"\n}" }
          }
        },
        {
          "name": "Logout",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('token', '');",
            "console.log('Token cleared.');"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout"
          }
        }
      ]
    },

    {
      "name": "💬 Chat",
      "item": [
        {
          "name": "Send Chat Message (normal)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.test('Has reply', () => pm.expect(r.reply).to.be.a('string'));",
            "pm.test('Has session_id', () => pm.expect(r.session_id).to.exist);",
            "console.log('Reply preview:', r.reply?.substring(0, 100));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/chat/query",
            "body": { "mode": "raw", "raw": "{\n  \"message\": \"Tôi muốn nấu cà chua trứng, cần mua nguyên liệu gì?\"\n}" }
          }
        },
        {
          "name": "Send Chat — Trigger Shopping Intent",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "if (r.shopping_suggestion) {",
            "  const s = r.shopping_suggestion;",
            "  console.log('🛒 Shopping intent detected!');",
            "  console.log('  Store:', s.cart_mandate?.store_name);",
            "  console.log('  Items:', s.cart_mandate?.items?.length);",
            "  console.log('  Total:', s.estimated_total, 'k VND');",
            "  pm.test('Has cart_mandate', () => pm.expect(s.cart_mandate).to.exist);",
            "} else {",
            "  console.log('ℹ️ No shopping intent — retry or rephrase the message');",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/chat/query",
            "body": { "mode": "raw", "raw": "{\n  \"message\": \"Giúp tôi mua 1kg cà chua, 6 quả trứng gà và 1 bó rau cải nhé\"\n}" }
          }
        },
        {
          "name": "Confirm Purchase (from chat suggestion)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.test('Order confirmed', () => pm.expect(r.status).to.be.oneOf(['paid','confirmed','pending_confirmation']));",
            "pm.test('Has transaction_id', () => pm.expect(r.transaction_id).to.be.a('string'));",
            "if (r.order_id) pm.collectionVariables.set('order_id', String(r.order_id));",
            "console.log('✅ Order:', r.order_id, '| Status:', r.status, '| Txn:', r.transaction_id);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/chat/confirm-purchase",
            "body": { "mode": "raw", "raw": "{\n  \"cart_mandate\": {\n    \"store_id\": \"bhx\",\n    \"store_name\": \"Bách Hóa Xanh\",\n    \"items\": [\n      {\n        \"product_id\": \"b1\",\n        \"product_name\": \"Cà chua\",\n        \"product_emoji\": \"🍅\",\n        \"unit\": \"kg\",\n        \"quantity\": 1,\n        \"unit_price\": 15.0,\n        \"subtotal\": 15.0\n      },\n      {\n        \"product_id\": \"b9\",\n        \"product_name\": \"Trứng gà\",\n        \"product_emoji\": \"🥚\",\n        \"unit\": \"vỉ 10\",\n        \"quantity\": 1,\n        \"unit_price\": 30.0,\n        \"subtotal\": 30.0\n      }\n    ],\n    \"subtotal\": 45.0,\n    \"delivery_fee\": 15.0,\n    \"estimated_total\": 60.0,\n    \"intent_description\": \"Mua nguyên liệu nấu cà chua trứng\"\n  }\n}" }
          }
        },
        {
          "name": "Chat History",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/chat/history"
          }
        }
      ]
    },

    {
      "name": "🍳 Recipes",
      "item": [
        {
          "name": "Suggest Recipe — AI (text)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.test('Has recipe data', () => pm.expect(r).to.exist);",
            "console.log('Response keys:', Object.keys(r).join(', '));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/recipes/suggest",
            "body": { "mode": "raw", "raw": "{\n  \"ingredients\": [\"cà chua\", \"trứng\", \"hành tây\"],\n  \"filters\": [],\n  \"meal_type\": \"lunch\"\n}" }
          }
        },
        {
          "name": "Suggest Recipe — Vegetarian filter",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/recipes/suggest",
            "body": { "mode": "raw", "raw": "{\n  \"ingredients\": [\"đậu phụ\", \"nấm\", \"cải xanh\"],\n  \"filters\": [\"chay\", \"ít dầu\"],\n  \"meal_type\": \"dinner\"\n}" }
          }
        },
        {
          "name": "List Saved Recipes",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));",
            "const r = pm.response.json();",
            "if (r.length > 0) pm.collectionVariables.set('recipe_id', String(r[0].id));",
            "console.log('Total saved recipes:', r.length);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/recipes?skip=0&limit=10",
              "host": ["{{base_url}}"], "path": ["recipes"],
              "query": [{"key":"skip","value":"0"},{"key":"limit","value":"10"}]
            }
          }
        },
        {
          "name": "Get Recipe Detail",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 or 404', () => pm.expect(pm.response.code).to.be.oneOf([200, 404]));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/recipes/{{recipe_id}}"
          }
        },
        {
          "name": "Save Recipe (manual)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const r = pm.response.json();",
            "if (r.id) pm.collectionVariables.set('recipe_id', String(r.id));",
            "console.log('Saved recipe id:', r.id);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/recipes",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Cà chua trứng\",\n  \"description\": \"Món ăn đơn giản, ngon miệng\",\n  \"ingredients\": [\"cà chua\", \"trứng\", \"hành lá\", \"dầu ăn\"],\n  \"steps\": [\"Đập trứng vào bát đánh đều\", \"Xào cà chua với dầu\", \"Thêm trứng vào xào\"],\n  \"nutrition\": { \"calories\": 250, \"protein\": 12, \"carbs\": 8, \"fat\": 18 },\n  \"meal_type\": \"lunch\",\n  \"cooking_time\": 15\n}" }
          }
        },
        {
          "name": "Delete Recipe",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204 or 404', () => pm.expect(pm.response.code).to.be.oneOf([204, 404]));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/recipes/{{recipe_id}}"
          }
        }
      ]
    },

    {
      "name": "📸 Vision",
      "item": [
        {
          "name": "Recognize Ingredients from Image",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.test('Has ingredients', () => pm.expect(r.ingredients || r).to.exist);",
            "console.log('Detected:', JSON.stringify(r.ingredients || r));"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/ingredients/recognize",
            "body": {
              "mode": "formdata",
              "formdata": [{
                "key": "file",
                "type": "file",
                "src": "",
                "description": "Upload ảnh (jpg/png) chứa nguyên liệu"
              }]
            }
          }
        }
      ]
    },

    {
