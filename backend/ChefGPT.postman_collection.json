            "console.log('Total memories:', arr.length);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/memory/me?skip=0&limit=50",
              "host": ["{{base_url}}"], "path": ["memory","me"],
              "query": [{"key":"skip","value":"0"},{"key":"limit","value":"50"}]
