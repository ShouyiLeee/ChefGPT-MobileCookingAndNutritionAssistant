# Application
APP_NAME=ChefGPT
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=change-this-secret-key

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Database
# SQLite (default for local dev — no setup needed)
DATABASE_URL=sqlite:///./chefgpt.db
# PostgreSQL (uncomment when deploying to Railway/Render)
# DATABASE_URL=postgresql://user:password@host:5432/chefgpt

# Supabase (Auth only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# JWT
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini 2.5 Flash — get free API key at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# Multiple keys for rotation (comma-separated). Overrides GEMINI_API_KEY if set.
GEMINI_API_KEYS=key1,key2,key3

# LLM Provider — "gemini" (default) | "openai" | "anthropic"
LLM_PROVIDER=gemini

# OpenAI (optional — only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional — only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Redis Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_RECIPES=3600
CACHE_TTL_MEAL_PLANS=1800

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/chefgpt.log
