# Application
APP_NAME=ChefGPT
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=change-this-secret-key

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Database
# SQLite (default for local dev — no setup needed)
DATABASE_URL=sqlite:///./chefgpt.db
# PostgreSQL (uncomment when deploying to Railway/Render)
# DATABASE_URL=postgresql://user:password@host:5432/chefgpt

# Supabase (Auth only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# JWT
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini 2.5 Flash — get free API key at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=INFO
